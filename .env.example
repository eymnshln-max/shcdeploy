# Optional. Leave empty until online mode is needed.
# Never paste this key into HTML or commit it to Git.
# ANTHROPIC_API_KEY=sk-ant-...

# Change this if your Anthropic account uses another model.
CLAUDE_MODEL=claude-sonnet-4-6

# Local server settings. Render provides PORT automatically.
HOST=127.0.0.1
PORT=4173

# Set to 0 for normal app entry. Set to 1 only when forcing online-only validation mode.
ONLINE_TEST_ONLY=0

# Optional: request timeout in milliseconds.
CLAUDE_TIMEOUT_MS=120000

# Optional: set to 1 only when full request/response logging is intentionally required.
TEST_LOG_CONTENT=0

{
  "name": "standard-healthcare",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Standard HealthCare clinical triage support app with offline assessment and an optional server-side Claude bridge.",
  "scripts": {
    "dev": "node server.mjs",
    "build": "vite build",
    "start": "node server.mjs --production",
    "typecheck": "tsc --noEmit",
    "check": "node scripts/check-config.mjs && tsc --noEmit && vite build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "^6.0.3",
    "vite": "8.1.3"
  }
}
